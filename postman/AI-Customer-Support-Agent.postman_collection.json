{
  "info": {
    "name": "AI Customer Support Agent",
    "description": "Samsung D2C AI Customer Support API — Docker local: http://localhost:3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
