      "name": "Health & Docs",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Support API",
      "item": [
        {
          "name": "Submit Support Request — ORD1001 (Coupon)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Kumaran\",\n  \"customerMessage\": \"My Samsung TV order hasn't arrived. Please help me.\",\n  \"orderId\": \"ORD1001\"\n}"
            },
            "url": "{{baseUrl}}/api/support"
          }
        },
        {
          "name": "Submit Support Request — ORD1002 (Delivered)",
          "request": {
            "method": "POST",
